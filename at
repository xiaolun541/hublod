-- Base64 解码，隐藏远程脚本地址
local function Decode64(str)
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    str = str:gsub("[^"..chars.."]","")
    local output, i = "", 1
    repeat
        local c1 = chars:find(str:sub(i,i))-1
        local c2 = chars:find(str:sub(i+1,i+1))-1
        local c3 = chars:find(str:sub(i+2,i+2))-1
        local c4 = chars:find(str:sub(i+3,i+3))-1
        local b1 = bit32.lshift(c1,2)+bit32.rshift(c2,4)
        local b2 = bit32.lshift(bit32.band(c2,15),4)+bit32.rshift(c3,2)
        local b3 = bit32.lshift(bit32.band(c3,3),6)+c4
        output = output..string.char(b1)
        if c3 ~= 64 then output = output..string.char(b2) end
        if c4 ~= 64 then output = output..string.char(b3) end
        i += 4
    until i>#str
    return output
end

