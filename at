-- 校验&加载逻辑
LoadBtn.MouseButton1Click:Connect(function()
    local IsAuth = false
    ErrorText.Visible = false

    -- 匹配白名单用户名
    for _,AllowedName in ipairs(Whitelist) do
        if LocalPlayer.Name == AllowedName then
            IsAuth = true
            break
        end
    end

    if IsAuth then
        ScreenUI:Destroy()
        print("身份校验通过，正在加载远程脚本...")
        -- request 请求加载
        local Response = request({
            Url = RemoteUrl;
            Method = "GET"
        })
        if Response.Success then
            loadstring(Response.Body)()
        else
            warn("脚本加载失败，网络/链接异常")
            ErrorText.Visible = true
        end
    else
        ErrorText.Visible = true
    end
end)
